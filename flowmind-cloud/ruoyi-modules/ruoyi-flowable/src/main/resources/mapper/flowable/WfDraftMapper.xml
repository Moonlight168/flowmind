<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.flowable.workflow.mapper.WfDraftMapper">

    <resultMap type="WfDraft" id="WfDraftResult">
        <result property="draftId"      column="draft_id"      />
        <result property="userId"       column="user_id"       />
        <result property="definitionId" column="definition_id" />
        <result property="deployId"     column="deploy_id"     />
        <result property="processName"  column="process_name"  />
        <result property="formData"     column="form_data"     />
        <result property="formModel"    column="form_model"    />
        <result property="delFlag"      column="del_flag"      />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectWfDraftVo">
        select draft_id, user_id, definition_id, deploy_id, process_name, form_data, form_model, del_flag, create_by, create_time, update_by, update_time, remark from wf_draft
    </sql>

    <select id="selectDraftVoList" parameterType="com.baomidou.mybatisplus.core.conditions.Wrapper" resultType="com.ruoyi.flowable.workflow.domain.vo.WfDraftVo">
        <include refid="selectWfDraftVo"/>
        ${ew.customSqlSegment}
    </select>

    <select id="selectByUserIdAndDefId" resultType="com.ruoyi.flowable.workflow.domain.vo.WfDraftVo">
        <include refid="selectWfDraftVo"/>
        where user_id = #{userId} and definition_id = #{definitionId} and del_flag = '0'
        limit 1
    </select>

</mapper>